<?xml version="1.0" encoding="utf-8"?>
<!-- Caminho: app/src/main/res/values/themes.xml -->
<resources>
    <!-- Tema base para a SplashScreen API -->
    <style name="Theme.TEMAerovendas" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@color/navy_deep</item>
        <item name="android:navigationBarColor">@color/navy_deep</item>
        <item name="android:windowBackground">@color/navy_deep</item>
    </style>

    <!-- Tema para Splash Screen nativa (Android 12+) -->
    <style name="Theme.TEMAerovendas.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/navy_deep</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_foreground</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/navy_deep</item>
        <item name="postSplashScreenTheme">@style/Theme.TEMAerovendas</item>
    </style>
</resources>
